{
  "server_url": "paste-the-server-url-the-host-shared",
  "username": "paste-your-username-from-the-host",
  "swarm_password": "paste-your-password-the-host-shared",
  "c3_api_key": "paste-your-c3-api-key-here",
  "agents": [
    {
      "name": "my-claude-agent",
      "provider": "anthropic",
      "model": "claude-sonnet-4-7",
      "api_key_env": "ANTHROPIC_API_KEY",
      "compute": "c3",
      "hardware": "l40"
    },
    {
      "name": "my-gpt-agent",
      "provider": "openai",
      "model": "gpt-5",
      "api_key_env": "OPENAI_API_KEY",
      "compute": "c3",
      "hardware": "l40"
    },
    {
      "name": "mr-claude-agentic",
      "provider": "claude-code-agentic",
      "model": "claude-opus-4-7",
      "compute": "c3",
      "hardware": "l40"
    },
    {
      "name": "ms-openrouter",
      "provider": "openai",
      "model": "qwen/qwen3-coder",
      "api_key_env": "OPENROUTER_API_KEY",
      "api_base": "https://openrouter.ai/api/v1",
      "compute": "c3",
      "hardware": "l40"
    },
    {
      "name": "my-deepseek-bot",
      "provider": "openai",
      "model": "deepseek-v4-pro",
      "api_key_env": "DEEPSEEK_API_KEY",
      "api_base": "https://api.deepseek.com/v1",
      "compute": "c3",
      "hardware": "l40"
    }
  ]
}
